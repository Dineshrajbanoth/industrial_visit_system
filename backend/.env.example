PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/industrial_visit
JWT_SECRET=replace_this_with_a_long_secure_random_string
JWT_EXPIRES_IN=1d

# Admin registration guard
ALLOW_ADMIN_REGISTRATION=true

# Option A: shared secret code
ADMIN_SECRET=replace_with_long_random_secret

# Option B: email allow-list (comma separated)
ADMIN_WHITELIST_EMAILS=admin1@example.com,admin2@example.com

# Optional security tuning
ADMIN_BCRYPT_ROUNDS=12

# Optional cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
